{
  "manifest_version": 3,
  "name": "Whatsapp Upgrade",
  "version": "1.0",
  "description": "Improves Whatsapp web UI.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Trigger Event",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
	"matches": ["https://web.whatsapp.com/"],
	"js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
