{
  "manifest_version": 3,
  "name": "Simple Button Trigger",
  "version": "1.0",
  "description": "Toolbar button triggers event in current tab",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Trigger Event"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}